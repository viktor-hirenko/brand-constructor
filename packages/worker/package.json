{
  "name": "@brand-constructor/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "type-check": "tsc --noEmit",
    "db:migrate": "wrangler d1 execute brand-constructor-db --local --file=./src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute brand-constructor-db --remote --file=./src/db/schema.sql",
    "db:seed": "wrangler d1 execute brand-constructor-db --local --file=./src/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute brand-constructor-db --remote --file=./src/db/seed.sql"
  },
  "dependencies": {
    "@brand-constructor/shared": "workspace:*",
    "hono": "^4.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
